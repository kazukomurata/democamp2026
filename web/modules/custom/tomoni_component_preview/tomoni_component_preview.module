<?php

/**
 * @file
 * Hooks for the Tomoni Component Preview module.
 */

/**
 * Implements hook_theme().
 */
function tomoni_component_preview_theme(array $existing, string $type, string $theme, string $path): array {
  return [
    'tomoni_component_preview' => [
      'variables' => [
        'sample_image' => NULL,
      ],
      'template' => 'tomoni-component-preview',
    ],
  ];
}
