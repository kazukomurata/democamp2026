{% set cta_style_map = {
  'primary': 'solid-fill',
  'secondary': 'outline',
  'solid-fill': 'solid-fill',
  'outline': 'outline',
  'text': 'text',
} %}
{% set cta_style = cta_style_map[style|default('solid-fill')] ?? 'solid-fill' %}
{% set cta_size = size in ['lg', 'md', 'sm'] ? size : 'md' %}
{% set cta_alignment = alignment in ['left', 'center'] ? alignment : 'left' %}
{% set cta_link_text = link_text|default('詳しく見る') %}
{% set cta_attributes = (attributes ?? create_attribute()).addClass([
  'tomoni-cta',
  'tomoni-cta--' ~ (cta_style == 'outline' ? 'secondary' : 'primary'),
  'tomoni-cta--align-' ~ cta_alignment,
]) %}

<section{{ cta_attributes }}>
  <div class="tomoni-cta__content">
    {% if title %}
      <h2 class="tomoni-cta__title">{{ title }}</h2>
    {% endif %}

    {% if text %}
      <div class="tomoni-cta__text">
        {{ text|raw }}
      </div>
    {% endif %}
  </div>

  {% if link_url %}
    <a class="tomoni-cta__link" href="{{ link_url }}" data-type="{{ cta_style }}" data-size="{{ cta_size }}"><span>{{ cta_link_text }}</span></a>
  {% endif %}
</section>
